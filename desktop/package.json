{
  "name": "guimaraes-materiais-desktop",
  "version": "1.0.0",
  "description": "Guimarães Materiais para Construção - Aplicativo Desktop",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:frontend": "cd ../frontend && npm run build",
    "build:exe": "npm run build:frontend && electron-builder build --win",
    "dev": "npm run build:frontend && electron ."
  },
  "build": {
    "appId": "com.guimaraes.materiais.desktop",
    "productName": "Guimarães Materiais",
    "directories": {
      "output": "C:\\Users\\KEIKO\\Desktop\\guimaraes-desktop"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend-dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerHeaderIcon": "icon.ico",
      "shortcutName": "Guimarães Materiais",
      "artifactName": "Guimaraes-Materiais-Setup-${version}.${ext}"
    }
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
